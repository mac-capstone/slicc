# Copy this file to .env and fill in your values.
# Never commit .env - it contains secrets.

# Google Places API (required for Explore places search)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Receipt OCR — full URL to your server POST /api/extract-receipt (Gemini key lives server-side only; see /server)
# Example local: http://localhost:8787/api/extract-receipt  |  Android emulator host: http://10.0.2.2:8787/api/extract-receipt
EXPO_PUBLIC_RECEIPT_EXTRACTION_URL=

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
