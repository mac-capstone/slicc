// Firestore Security Rules
// NOTE: Deploying this file replaces ALL Firestore rules. Merge with existing
// rules for users, groups, events, expenses if you have them in Firebase Console.
//
// Users collection: authenticated clients must be able to read peer public profiles
// (including `dietaryPreferenceIds` denormalized from private settings) for Explore
// recommendations. Ensure your merged production rules allow signed-in reads of
// `users/{userId}` fields needed for social features.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Place likes - collaborative recommendations
    // Read: any authenticated user (needed for "users who liked X")
    // Write: only the document owner
    match /placeLikes/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
